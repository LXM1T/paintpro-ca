{
  "version": 2,
  "name": "paintpro-ca",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles/**", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" },
    { "src": "tests/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/styles/(.*)", "dest": "/styles/$1" },
    { "src": "/src/(.*)",    "dest": "/src/$1" },
    { "src": "/tests/(.*)",  "dest": "/tests/$1" },
    { "src": "/(.*)\\.css",  "dest": "/$1.css" },
    { "src": "/(.*)\\.js",   "dest": "/$1.js" },
    { "src": "/",            "dest": "/index.html" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.css",
      "headers": [{ "key": "Content-Type", "value": "text/css" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
